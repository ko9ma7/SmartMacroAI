<Window x:Class="SmartMacroAI.CoordinatePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick Coordinate"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowState="Maximized"
        ShowInTaskbar="False"
        Cursor="Cross"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        KeyDown="Window_KeyDown">
    <Grid Background="#01000000">
        <Canvas x:Name="GuideCanvas" />
        <TextBlock Text="Di chuyển chuột đến vị trí cần lấy tọa độ. Nhấp chuột trái để xác nhận. ESC để hủy."
                   Foreground="#89B4FA"
                   FontSize="18"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0, 50, 0, 0"
                   Opacity="0.9">
            <TextBlock.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.8" Color="Black" />
            </TextBlock.Effect>
        </TextBlock>
    </Grid>
</Window>

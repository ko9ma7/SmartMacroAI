    <system:String x:Key="ui_Settings_Telegram_SaveButton">💾 Save Telegram</system:String>
    <system:String x:Key="ui_Settings_Telegram_HowToTitle">How to get your credentials:</system:String>
    <system:String x:Key="ui_Settings_Telegram_Step1">Bot Token: Open Telegram → @BotFather → /newbot → set name → copy token (format: 123456789:ABCdefGHI...)</system:String>
    <system:String x:Key="ui_Settings_Telegram_Step2">Chat ID: Add bot to group/channel → send /start → visit t.me/getidsbot to get the Chat ID.</system:String>
    <system:String x:Key="ui_Settings_Telegram_Step3">Proxy: If needed, enter proxy in the Proxy field in AdsPower Profile or use system proxy.</system:String>

<Window x:Class="SmartMacroAI.MacroLockDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔒 Khóa Macro"
        Height="280" Width="380"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="🔒 Đặt mật khẩu khóa macro"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="#CDD6F4" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Mật khẩu mới:" Foreground="#6C7086" FontSize="11" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PwdNew" Height="32" FontSize="13"
                        Background="#313244" Foreground="#CDD6F4"
                        BorderBrush="#45475A" Padding="8,6"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Xác nhận mật khẩu:" Foreground="#6C7086" FontSize="11" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PwdConfirm" Height="32" FontSize="13"
                        Background="#313244" Foreground="#CDD6F4"
                        BorderBrush="#45475A" Padding="8,6"/>
        </StackPanel>

        <TextBlock Grid.Row="3" x:Name="TxtError" Foreground="#F38BA8"
                   FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnRemoveLock" Content="Xóa khóa"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BtnRemoveLock_Click" Margin="0,0,8,0"/>
            <Button Content="Hủy"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BtnCancel_Click" Margin="0,0,8,0"/>
            <Button Content="Lưu"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="BtnSetLock_Click"/>
        </StackPanel>
    </Grid>
</Window>

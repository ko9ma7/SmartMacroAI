<Window x:Class="SmartMacroAI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SmartMacroAI"
        Height="720" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BaseBrush}"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Geometry x:Key="DashboardIcon">M4 13h6a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1zm-1 7h6a1 1 0 0 0 1-1v-4a1 1 0 0 0-1-1H4a1 1 0 0 0-1 1v4a1 1 0 0 0 1 1zm10 0h6a1 1 0 0 0 1-1v-8a1 1 0 0 0-1-1h-6a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1zM13 4v4a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4a1 1 0 0 0-1-1h-6a1 1 0 0 0-1 1z</Geometry>
        <Geometry x:Key="MacroIcon">M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zM9 13l2 2-2 2M15 13l-2 2 2 2</Geometry>
        <Geometry x:Key="ImageIcon">M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2zM8.5 9.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zM21 15l-5-5L5 21</Geometry>
        <Geometry x:Key="OcrIcon">M17 8h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2h-2M7 8H5a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2M7 12h10</Geometry>
        <Geometry x:Key="SettingsIcon">M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z</Geometry>
        <Geometry x:Key="AboutIcon">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z</Geometry>
        <Geometry x:Key="StealthIcon">M13.875 18.825A10.05 10.05 0 0 1 12 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 0 1 4.02-5.272M6.61 6.61A9.97 9.97 0 0 1 12 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 0 1-4.132 5.411m-5.154-.776a3 3 0 0 1-4.243-4.243M2 2l20 20</Geometry>
        <Geometry x:Key="PlayIcon">M5 3l14 9-14 9V3z</Geometry>
        <Geometry x:Key="StopIcon">M6 4h4v16H6zM14 4h4v16h-4z</Geometry>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ==================== SIDEBAR ==================== -->
        <Border Grid.Column="0" Grid.RowSpan="2"
                Background="{StaticResource MantelBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="20,24,20,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Border Width="36" Height="36" CornerRadius="8" Margin="0,0,10,0">
                                <Border.Background>
                                    <ImageBrush ImageSource="/Assets/logo.png" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="SmartMacroAI" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}" />
                                <TextBlock Text="v1.0.0" FontSize="10"
                                           Foreground="{StaticResource OverlayBrush}" Margin="0,-1,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border DockPanel.Dock="Top" Height="1" Margin="16,0" Background="{StaticResource Surface0Brush}" />
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8">
                    <Border Height="1" Margin="16,8" Background="{StaticResource Surface0Brush}" />
                    <Button x:Name="BtnAbout" Style="{StaticResource SidebarButtonStyle}" Click="BtnAbout_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource AboutIcon}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" />
                            <TextBlock Text="About" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnSettingsNav" Style="{StaticResource SidebarButtonStyle}" Click="BtnSettings_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource SettingsIcon}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" Fill="Transparent" />
                            <TextBlock Text="Settings" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="NAVIGATION" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource OverlayBrush}" Margin="24,8,0,8" />
                        <Button x:Name="BtnDashboard" Style="{StaticResource SidebarButtonActiveStyle}" Click="BtnDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource DashboardIcon}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" />
                                <TextBlock Text="Dashboard" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnMacroEditor" Style="{StaticResource SidebarButtonStyle}" Click="BtnMacroEditor_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource MacroIcon}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" />
                                <TextBlock Text="Macro Editor" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnImageRecognition" Style="{StaticResource SidebarButtonStyle}" Click="BtnImageRecognition_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource ImageIcon}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" />
                                <TextBlock Text="Image Recognition" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnOcrEngine" Style="{StaticResource SidebarButtonStyle}" Click="BtnOcrEngine_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource OcrIcon}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" />
                                <TextBlock Text="OCR Engine" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnStealthManager" Style="{StaticResource SidebarButtonStyle}" Click="BtnStealthManager_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource StealthIcon}" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Fill="Transparent" Width="20" Height="20" Stretch="Uniform" Margin="0,0,12,0" />
                                <TextBlock Text="Stealth Manager" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ==================== MAIN CONTENT AREA ==================== -->
        <Grid Grid.Column="1" Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top Header Bar -->
            <Border Grid.Row="0" Background="{StaticResource BaseBrush}" Padding="24,16" BorderBrush="{StaticResource Surface0Brush}" BorderThickness="0,0,0,1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{StaticResource Surface0Brush}" CornerRadius="6" Padding="12,6" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush x:Name="StatusIndicator" Color="{StaticResource AccentGreenColor}" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock x:Name="TxtStatus" Text="Ready" FontSize="12" Foreground="{StaticResource SubtextBrush}" />
                            </StackPanel>
                        </Border>
                        <Button x:Name="BtnRecordMacro" Style="{StaticResource DangerButtonStyle}" Click="BtnRecordMacro_Click" Margin="0,0,8,0" Padding="16,10">
                            <TextBlock><Run Text="&#x23FA;" /><Run Text=" Record" /></TextBlock>
                        </Button>
                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="+ New Macro" Click="BtnNewMacro_Click" />
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TxtPageTitle" Text="Dashboard" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                        <TextBlock x:Name="TxtPageSubtitle" Text="Multi-tasking hub — run multiple macros simultaneously" FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Content Frame -->
            <Border Grid.Row="1" Padding="24,16,24,8">
                <Grid x:Name="ContentArea">

                    <!-- ────── Dashboard View (Trạm điều hành đa nhiệm) ────── -->
                    <Grid x:Name="DashboardView">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Stats Row -->
                        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,12">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="Saved Macros" FontSize="12" Foreground="{StaticResource SubtextBrush}" />
                                    <TextBlock x:Name="TxtTotalMacros" Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentBlueBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="4,0">
                                <StackPanel>
                                    <TextBlock Text="Runs Today" FontSize="12" Foreground="{StaticResource SubtextBrush}" />
                                    <TextBlock x:Name="TxtRunsToday" Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentGreenBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Active Threads" FontSize="12" Foreground="{StaticResource SubtextBrush}" />
                                    <TextBlock x:Name="TxtActiveThreads" Text="0" FontSize="32" FontWeight="Bold" Foreground="{StaticResource AccentPeachBrush}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- DataGrid Multi-tasking Hub -->
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0" Padding="0">
                            <DockPanel>
                                <DockPanel DockPanel.Dock="Top" Margin="16,12,16,8">
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Style="{StaticResource DangerButtonStyle}" Content="&#x23F9; STOP ALL" Click="BtnStopAllMacros_Click" Padding="12,6" FontSize="11" Margin="0,0,6,0" />
                                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="&#x21BB; Refresh" Click="BtnRefreshDashboard_Click" Padding="12,6" FontSize="11" />
                                    </StackPanel>
                                    <TextBlock Text="Trạm điều hành đa nhiệm" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                </DockPanel>
                                <Grid>
                                    <TextBlock x:Name="DashboardEmptyHint"
                                               Text="Chưa có kịch bản nào. Hãy tạo và lưu macro trong Macro Editor."
                                               FontSize="13" Foreground="{StaticResource OverlayBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Margin="0,40,0,0" Visibility="Collapsed" />
                                    <DataGrid x:Name="DashboardGrid"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False" CanUserDeleteRows="False"
                                              CanUserReorderColumns="False" CanUserSortColumns="False"
                                              IsReadOnly="True"
                                              SelectionMode="Single" SelectionUnit="FullRow"
                                              HeadersVisibility="Column"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="{StaticResource Surface1Brush}"
                                              Background="{StaticResource BaseBrush}"
                                              RowBackground="#1E1E2E"
                                              AlternatingRowBackground="#21213A"
                                              BorderThickness="0"
                                              ColumnHeaderHeight="36"
                                              RowHeight="48"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">

                                        <DataGrid.ColumnHeaderStyle>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="{StaticResource MantelBrush}" />
                                                <Setter Property="Foreground" Value="{StaticResource SubtextBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Setter Property="FontSize" Value="11" />
                                                <Setter Property="Padding" Value="10,8" />
                                                <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}" />
                                                <Setter Property="BorderThickness" Value="0,0,1,1" />
                                            </Style>
                                        </DataGrid.ColumnHeaderStyle>

                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#2A2A3D" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#2A2A3D" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>

                                        <DataGrid.CellStyle>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Focusable" Value="False" />
                                                <Setter Property="IsHitTestVisible" Value="True" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="DataGridCell">
                                                            <ContentPresenter VerticalAlignment="Center" Margin="6,4" />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </DataGrid.CellStyle>

                                        <DataGrid.Columns>
                                            <!-- Tên kịch bản -->
                                            <DataGridTemplateColumn Header="Tên kịch bản" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <DockPanel VerticalAlignment="Center" LastChildFill="True">
                                                            <Button DockPanel.Dock="Right" Content="✎" Click="DashboardRename_Click"
                                                                    ToolTip="Rename Macro" FontSize="12" Padding="8,4" Margin="8,0,0,0"
                                                                    Cursor="Hand" VerticalAlignment="Center"
                                                                    Background="#45475A" Foreground="#CDD6F4" BorderThickness="0" FontWeight="SemiBold" />
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding MacroName}" FontWeight="SemiBold" FontSize="12" Foreground="#CDD6F4" />
                                                                <TextBlock Text="{Binding ActionCount, StringFormat='{}{0} actions'}" FontSize="10" Foreground="#6C7086" />
                                                            </StackPanel>
                                                        </DockPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Cửa sổ mục tiêu -->
                                            <DataGridTemplateColumn Header="Cửa sổ mục tiêu" Width="200">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <ComboBox Text="{Binding TargetWindow, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                  IsEditable="True" FontSize="11"
                                                                  Background="#313244" Foreground="#CDD6F4"
                                                                  BorderThickness="1" BorderBrush="#45475A"
                                                                  Padding="4,2" Margin="2"
                                                                  DropDownOpened="DashRowWindowCombo_DropDownOpened" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Stealth Mode -->
                                            <DataGridTemplateColumn Header="Stealth" Width="60">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding StealthMode, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                  ToolTip="Ẩn cửa sổ mục tiêu khi chạy" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Số lần chạy -->
                                            <DataGridTemplateColumn Header="Số lần chạy" Width="85">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding RunCount, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                                                                 FontSize="11" TextAlignment="Center"
                                                                 Background="#313244" Foreground="#CDD6F4"
                                                                 BorderThickness="1" BorderBrush="#45475A"
                                                                 Padding="4,3" Margin="2"
                                                                 ToolTip="0 = vô hạn" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Giãn cách -->
                                            <DataGridTemplateColumn Header="Giãn cách (phút)" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBox Text="{Binding IntervalMinutes, UpdateSourceTrigger=LostFocus, Mode=TwoWay}"
                                                                 FontSize="11" TextAlignment="Center"
                                                                 Background="#313244" Foreground="#CDD6F4"
                                                                 BorderThickness="1" BorderBrush="#45475A"
                                                                 Padding="4,3" Margin="2"
                                                                 ToolTip="0 = không giãn cách" />
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Trạng thái -->
                                            <DataGridTemplateColumn Header="Trạng thái" Width="100">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#A6E3A1" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Đang chạy">
                                                                            <Setter Property="Foreground" Value="#F9E2AF" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Đang chờ">
                                                                            <Setter Property="Foreground" Value="#89B4FA" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Đã dừng">
                                                                            <Setter Property="Foreground" Value="#F38BA8" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="Lỗi">
                                                                            <Setter Property="Foreground" Value="#F38BA8" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>

                                            <!-- Điều khiển -->
                                            <DataGridTemplateColumn Header="Điều khiển" Width="160">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Content="▶ Start" Click="DashboardStart_Click"
                                                                    IsEnabled="{Binding CanStart}"
                                                                    FontSize="11" Padding="8,4" Cursor="Hand"
                                                                    Background="#A6E3A1" Foreground="#1E1E2E"
                                                                    BorderThickness="0" Margin="0,0,4,0"
                                                                    FontWeight="SemiBold" />
                                                            <Button Content="⏹" Click="DashboardStop_Click"
                                                                    IsEnabled="{Binding CanStop}"
                                                                    FontSize="11" Padding="8,4" Cursor="Hand"
                                                                    Background="#F38BA8" Foreground="White"
                                                                    BorderThickness="0" Margin="0,0,4,0"
                                                                    FontWeight="SemiBold" />
                                                            <Button Content="🗑" Click="DashboardDelete_Click"
                                                                    FontSize="11" Padding="8,4" Cursor="Hand"
                                                                    Background="#585B70" Foreground="White"
                                                                    BorderThickness="0" FontWeight="SemiBold"
                                                                    ToolTip="Xóa kịch bản" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- ────── Macro Editor View ────── -->
                    <Grid x:Name="MacroEditorView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="12">
                            <WrapPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="MACRO NAME" />
                                    <TextBox x:Name="TxtMacroName" Style="{StaticResource DarkTextBoxStyle}" Width="180" Text="Untitled Macro" />
                                </StackPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="TARGET WINDOW TITLE" />
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="&#x21BB;" Click="BtnRefreshWindows_Click" ToolTip="Refresh window list" FontSize="14" Cursor="Hand" Margin="4,0,0,0" Background="{StaticResource Surface0Brush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="8,6" />
                                        <ComboBox x:Name="CmbTargetWindow" Width="220" IsEditable="True" Background="{StaticResource BaseBrush}" Foreground="{StaticResource TextBrush}" FontSize="12" ToolTip="Select or type a window title" DropDownOpened="CmbTargetWindow_DropDownOpened" />
                                    </DockPanel>
                                </StackPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Style="{StaticResource FieldLabelStyle}" Text="REPEAT" />
                                    <TextBox x:Name="TxtRepeatCount" Style="{StaticResource DarkTextBoxStyle}" Width="60" Text="1" ToolTip="0 = infinite loop" />
                                </StackPanel>
                                <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal">
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Save" Click="BtnSaveMacro_Click" Margin="0,0,6,0" Padding="16,8" />
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="Load" Click="BtnLoadMacro_Click" Margin="0,0,6,0" Padding="16,8" />
                                    <Button Style="{StaticResource DangerButtonStyle}" Content="Clear" Click="BtnClearCanvas_Click" Margin="0,0,6,0" Padding="16,8" />
                                    <Border Width="1" Background="{StaticResource Surface1Brush}" Margin="4,2,10,2" />
                                    <Button x:Name="BtnRunMacro" Click="BtnRunMacro_Click" Padding="16,8" Cursor="Hand"
                                            Background="#A6E3A1" Foreground="#1E1E2E" BorderThickness="0" FontWeight="SemiBold" FontSize="12"
                                            Content="▶ Run" />
                                    <Button x:Name="BtnStopMacro" Click="BtnStopMacro_Click" IsEnabled="False" Padding="16,8" Cursor="Hand" Margin="6,0,0,0"
                                            Background="#F38BA8" Foreground="White" BorderThickness="0" FontWeight="SemiBold" FontSize="12"
                                            Content="⏹ Stop" />
                                </StackPanel>
                            </WrapPanel>
                        </Border>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="Actions" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                                    <StackPanel>
                                        <Border Background="{StaticResource BaseBrush}" CornerRadius="6" Padding="10,8" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="Click"><Ellipse Width="8" Height="8" Fill="{StaticResource AccentBlueBrush}" Margin="0,0,10,0" /><TextBlock Text="Click" Foreground="{StaticResource TextBrush}" FontSize="12" /></StackPanel></Border>
                                        <Border Background="{StaticResource BaseBrush}" CornerRadius="6" Padding="10,8" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="TypeText"><Ellipse Width="8" Height="8" Fill="{StaticResource AccentGreenBrush}" Margin="0,0,10,0" /><TextBlock Text="Type Text" Foreground="{StaticResource TextBrush}" FontSize="12" /></StackPanel></Border>
                                        <Border Background="{StaticResource BaseBrush}" CornerRadius="6" Padding="10,8" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="Wait"><Ellipse Width="8" Height="8" Fill="{StaticResource AccentYellowBrush}" Margin="0,0,10,0" /><TextBlock Text="Wait" Foreground="{StaticResource TextBrush}" FontSize="12" /></StackPanel></Border>
                                        <Border Background="{StaticResource BaseBrush}" CornerRadius="6" Padding="10,8" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="IfImageFound"><Ellipse Width="8" Height="8" Fill="{StaticResource AccentPeachBrush}" Margin="0,0,10,0" /><TextBlock Text="IF Image Found" Foreground="{StaticResource TextBrush}" FontSize="12" /></StackPanel></Border>
                                        <Border Background="{StaticResource BaseBrush}" CornerRadius="6" Padding="10,8" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="IfTextFound"><Ellipse Width="8" Height="8" Fill="{StaticResource AccentLavenderBrush}" Margin="0,0,10,0" /><TextBlock Text="IF Text Found" Foreground="{StaticResource TextBrush}" FontSize="12" /></StackPanel></Border>
                                        <TextBlock Text="WEB (Playwright)" FontSize="10" FontWeight="SemiBold" Foreground="#94E2D5" Margin="0,14,0,6" />
                                        <Border Background="#1A3D3A" CornerRadius="6" Padding="10,8" Margin="0,2" BorderBrush="#94E2D5" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="WebNavigate"><TextBlock Text="&#x1F310;" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center" /><TextBlock Text="Web: Navigate" Foreground="#94E2D5" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" /></StackPanel></Border>
                                        <Border Background="#1A3D3A" CornerRadius="6" Padding="10,8" Margin="0,2" BorderBrush="#94E2D5" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="WebClick"><TextBlock Text="&#x1F310;" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center" /><TextBlock Text="Web: Click" Foreground="#94E2D5" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" /></StackPanel></Border>
                                        <Border Background="#1A3D3A" CornerRadius="6" Padding="10,8" Margin="0,2" BorderBrush="#94E2D5" BorderThickness="1" Cursor="Hand" MouseLeftButtonDown="ActionBlock_MouseDown"><StackPanel Orientation="Horizontal" Tag="WebType"><TextBlock Text="&#x1F310;" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center" /><TextBlock Text="Web: Type" Foreground="#94E2D5" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" /></StackPanel></Border>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="Macro Workflow" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                                    <Border CornerRadius="8" Background="{StaticResource BaseBrush}" BorderBrush="{StaticResource Surface1Brush}" BorderThickness="2" AllowDrop="True" DragOver="Canvas_DragOver" Drop="Canvas_Drop">
                                        <Grid>
                                            <TextBlock x:Name="CanvasPlaceholder" Text="Drag actions here to build your macro" FontSize="14" Foreground="{StaticResource OverlayBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                <ItemsControl x:Name="MacroCanvas" Margin="12">
                                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </DockPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ────── Image Recognition View ────── -->
                    <Grid x:Name="ImageRecognitionView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Test Template Matching (Background Capture)" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                                <WrapPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="WINDOW TITLE" />
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="&#x21BB;" Click="BtnRefreshVisionWindows_Click" ToolTip="Refresh" FontSize="14" Cursor="Hand" Margin="4,0,0,0" Background="{StaticResource Surface0Brush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="8,6" />
                                            <ComboBox x:Name="CmbVisionWindowTitle" Width="220" IsEditable="True" Background="{StaticResource BaseBrush}" Foreground="{StaticResource TextBrush}" FontSize="12" DropDownOpened="CmbVisionWindowTitle_DropDownOpened" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="TEMPLATE IMAGE PATH" />
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButtonStyle}" Content="Browse" Click="BtnBrowseTemplate_Click" Padding="12,8" Margin="4,0,0,0" />
                                            <Button DockPanel.Dock="Right" Style="{StaticResource DangerButtonStyle}" Content="&#x2702; Snip" Click="BtnSnipArea_Click" Padding="12,8" Margin="4,0,0,0" />
                                            <TextBox x:Name="TxtTemplatePath" Style="{StaticResource DarkTextBoxStyle}" Width="220" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="THRESHOLD" />
                                        <TextBox x:Name="TxtThreshold" Style="{StaticResource DarkTextBoxStyle}" Width="60" Text="0.8" />
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,8">
                                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="Test Capture &amp; Match" Click="BtnTestVision_Click" Padding="16,8" />
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Result" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                                <Border CornerRadius="8" Background="{StaticResource BaseBrush}" Padding="16">
                                    <TextBlock x:Name="TxtVisionResult" Text="Run a test to see results here..." FontSize="13" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" />
                                </Border>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- ────── OCR Engine View ────── -->
                    <Grid x:Name="OcrEngineView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="16">
                            <StackPanel>
                                <TextBlock Text="Test OCR Text Extraction (Background Capture)" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                                <WrapPanel>
                                    <StackPanel Margin="0,0,16,8">
                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="WINDOW TITLE" />
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right" Content="&#x21BB;" Click="BtnRefreshOcrWindows_Click" ToolTip="Refresh" FontSize="14" Cursor="Hand" Margin="4,0,0,0" Background="{StaticResource Surface0Brush}" Foreground="{StaticResource TextBrush}" BorderThickness="0" Padding="8,6" />
                                            <ComboBox x:Name="CmbOcrWindowTitle" Width="280" IsEditable="True" Background="{StaticResource BaseBrush}" Foreground="{StaticResource TextBrush}" FontSize="12" DropDownOpened="CmbOcrWindowTitle_DropDownOpened" />
                                        </DockPanel>
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,8">
                                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="Extract Text" Click="BtnTestOcr_Click" Padding="16,8" />
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Extracted Text" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                                <Border CornerRadius="8" Background="{StaticResource BaseBrush}" Padding="16">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock x:Name="TxtOcrResult" Text="Run a test to see OCR results here..." FontSize="13" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Border>
                            </DockPanel>
                        </Border>
                    </Grid>

                    <!-- ────── Stealth Manager View ────── -->
                    <Grid x:Name="StealthManagerView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="16">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Style="{StaticResource DangerButtonStyle}" Content="Show All" Click="BtnShowAllStealth_Click" Padding="12,6" FontSize="11" Margin="0,0,6,0" />
                                    <Button Style="{StaticResource PrimaryButtonStyle}" Content="&#x21BB; Refresh" Click="BtnRefreshStealth_Click" Padding="12,6" FontSize="11" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Quản lý Stealth" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
                                    <TextBlock Text="Ẩn/hiện bất kỳ cửa sổ nào. Macro vẫn gửi click vào cửa sổ đã ẩn." FontSize="11" Foreground="{StaticResource SubtextBrush}" Margin="0,2,0,0" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="0">
                            <DataGrid x:Name="StealthGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False" CanUserDeleteRows="False"
                                      CanUserReorderColumns="False" CanUserSortColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single" SelectionUnit="FullRow"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{StaticResource Surface1Brush}"
                                      Background="{StaticResource BaseBrush}"
                                      RowBackground="#1E1E2E"
                                      AlternatingRowBackground="#21213A"
                                      BorderThickness="0"
                                      ColumnHeaderHeight="36"
                                      RowHeight="42"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">

                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="{StaticResource MantelBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource SubtextBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                        <Setter Property="FontSize" Value="11" />
                                        <Setter Property="Padding" Value="10,8" />
                                        <Setter Property="BorderBrush" Value="{StaticResource Surface1Brush}" />
                                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2A2A3D" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>

                                <DataGrid.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Focusable" Value="False" />
                                        <Setter Property="IsHitTestVisible" Value="True" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="DataGridCell">
                                                    <ContentPresenter VerticalAlignment="Center" Margin="8,4" />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </DataGrid.CellStyle>

                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Cửa sổ" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding WindowTitle}" FontSize="12" Foreground="#CDD6F4"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Trạng thái" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#A6E3A1" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                                    <Setter Property="Foreground" Value="#F38BA8" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTemplateColumn Header="Hành động" Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding ToggleLabel}" Click="StealthToggle_Click"
                                                        FontSize="11" Padding="10,4" Cursor="Hand"
                                                        BorderThickness="0" FontWeight="SemiBold">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="#F38BA8" />
                                                            <Setter Property="Foreground" Value="White" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHidden}" Value="True">
                                                                    <Setter Property="Background" Value="#A6E3A1" />
                                                                    <Setter Property="Foreground" Value="#1E1E2E" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>

                    <!-- ────── Settings View ────── -->
                    <Grid x:Name="SettingsView" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="600">
                                <!-- Global Hotkeys -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Global Hotkeys" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,4" />
                                        <TextBlock Text="Phím tắt toàn cục hoạt động ngay cả khi ứng dụng bị ẩn." FontSize="12" Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,16" />

                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="TOGGLE APP VISIBILITY (Ẩn/Hiện SmartMacroAI)" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,16">
                                            <ComboBox x:Name="CmbToggleAppMod" Width="130" Background="{StaticResource BaseBrush}" Foreground="{StaticResource TextBrush}" FontSize="12" />
                                            <TextBlock Text="  +  " FontSize="14" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center" />
                                            <ComboBox x:Name="CmbToggleAppKey" Width="90" Background="{StaticResource BaseBrush}" Foreground="{StaticResource TextBrush}" FontSize="12" />
                                        </StackPanel>

                                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="TOGGLE TARGET WINDOW (Ẩn/Hiện cửa sổ mục tiêu)" />
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,16">
                                            <ComboBox x:Name="CmbToggleTargetMod" Width="130" Background="{StaticResource BaseBrush}" Foreground="{StaticResource TextBrush}" FontSize="12" />
                                            <TextBlock Text="  +  " FontSize="14" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center" />
                                            <ComboBox x:Name="CmbToggleTargetKey" Width="90" Background="{StaticResource BaseBrush}" Foreground="{StaticResource TextBrush}" FontSize="12" />
                                        </StackPanel>

                                        <Button Style="{StaticResource PrimaryButtonStyle}" Content="Save Hotkeys" Click="BtnSaveHotkeys_Click" Padding="20,10" HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Border>

                                <!-- Tray Info -->
                                <Border Style="{StaticResource CardStyle}" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="System Tray" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource SubtextBrush}" Text="Khi ẩn bằng hotkey, ứng dụng sẽ thu nhỏ vào khay hệ thống (System Tray). Nhấp đúp vào biểu tượng tray hoặc nhấn phím tắt để hiện lại. Click chuột phải để xem menu khẩn cấp." />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ────── About View ────── -->
                    <Grid x:Name="AboutView" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="520" HorizontalAlignment="Center" Margin="0,8,0,24">
                                <!-- App Header with Logo -->
                                <Border CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{StaticResource AccentBlueColor}" Offset="0" />
                                            <GradientStop Color="{StaticResource AccentLavenderColor}" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="80" Height="80" CornerRadius="16" Margin="0,0,0,12" HorizontalAlignment="Center">
                                            <Border.Background>
                                                <ImageBrush ImageSource="/Assets/logo.png" Stretch="UniformToFill" />
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="SmartMacroAI" FontSize="28" FontWeight="Bold" Foreground="#11111B" HorizontalAlignment="Center" />
                                        <TextBlock Text="v1.0.0 — RPA Automation Tool" FontSize="13" Foreground="#313244" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <!-- Description -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Non-invasive automation for Windows 10/11. Uses Win32 API to send clicks and keystrokes directly to background windows without hijacking your physical mouse or keyboard."
                                                   TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource SubtextBrush}" LineHeight="20" />
                                        <Border Height="1" Background="{StaticResource Surface1Brush}" Margin="0,14" />
                                        <TextBlock Text="Technology Stack" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource OverlayBrush}" Margin="0,0,0,6" />
                                        <TextBlock Text=".NET 8.0  |  WPF  |  Win32 API  |  Emgu.CV (OpenCV)  |  Tesseract OCR" FontSize="11" Foreground="{StaticResource SubtextBrush}" />
                                    </StackPanel>
                                </Border>

                                <!-- Author Credit & Contact -->
                                <Border Style="{StaticResource CardStyle}" Padding="20" Margin="0,0,0,12">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="Created by Phạm Duy - Giải pháp tự động hóa thông minh."
                                                   FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"
                                                   HorizontalAlignment="Center" TextAlignment="Center" />
                                        <Border Height="1" Background="{StaticResource Surface1Brush}" Margin="0,12" />
                                        <TextBlock Text="Liên hệ hỗ trợ" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource OverlayBrush}" HorizontalAlignment="Center" Margin="0,0,0,6" />
                                        <TextBlock HorizontalAlignment="Center">
                                            <Hyperlink NavigateUri="https://www.facebook.com/neull" RequestNavigate="Hyperlink_RequestNavigate"
                                                       Foreground="{StaticResource AccentBlueBrush}" TextDecorations="None">
                                                facebook.com/neull
                                            </Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Coffee / Support -->
                                <Border CornerRadius="12" Padding="24,20" Margin="0,0,0,12">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#3E1E1E2E" Offset="0" />
                                            <GradientStop Color="#3E313244" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="{StaticResource AccentPeachColor}" Opacity="0.4" />
                                    </Border.BorderBrush>
                                    <Border.BorderThickness>1</Border.BorderThickness>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="&#x2615; Mời cà phê" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentPeachBrush}" HorizontalAlignment="Center" Margin="0,0,0,8" />
                                        <TextBlock Text="Mời tác giả một ly cà phê nếu phần mềm này giúp ích cho bạn!"
                                                   TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource SubtextBrush}"
                                                   HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,16" />
                                        <Border Width="220" Height="220" CornerRadius="12"
                                                Background="White"
                                                BorderBrush="{StaticResource Surface1Brush}" BorderThickness="2"
                                                HorizontalAlignment="Center" Padding="4">
                                            <Image Source="/Assets/qr_bank.png" Stretch="Uniform" />
                                        </Border>
                                        <TextBlock Text="MB Bank — PHAM QUOC DUY — 379997999" FontSize="10"
                                                   Foreground="{StaticResource SubtextBrush}" HorizontalAlignment="Center"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </Border>

            <!-- ────── Active Process Bar ────── -->
            <Border Grid.Row="2" Background="{StaticResource Surface0Brush}" Padding="16,6" BorderBrush="{StaticResource Surface1Brush}" BorderThickness="0,1,0,0">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Style="{StaticResource DangerButtonStyle}" Click="BtnStopAllMacros_Click" Padding="12,4" FontSize="11">
                        <TextBlock><Run Text="&#x23F9;" /><Run Text=" STOP ALL MACROS" /></TextBlock>
                    </Button>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="ProcessDot" Width="8" Height="8" Fill="{StaticResource AccentGreenBrush}" Margin="0,0,8,0" />
                        <TextBlock x:Name="TxtActiveProcesses" Text="Active: 0 macros running" FontSize="12" Foreground="{StaticResource SubtextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ────── Log Console Panel ────── -->
            <Border Grid.Row="3" Background="{StaticResource MantelBrush}" BorderBrush="{StaticResource Surface0Brush}" BorderThickness="0,1,0,0" MaxHeight="180">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="16,8,16,4">
                        <Button DockPanel.Dock="Right" Style="{StaticResource SidebarButtonStyle}" Content="Clear" Click="BtnClearLog_Click" FontSize="11" Padding="8,4" />
                        <TextBlock Text="LOG CONSOLE" FontSize="10" FontWeight="SemiBold" Foreground="{StaticResource OverlayBrush}" VerticalAlignment="Center" />
                    </DockPanel>
                    <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" Margin="16,0,16,8">
                        <TextBlock x:Name="TxtLogConsole" FontSize="11" FontFamily="Consolas" Foreground="{StaticResource SubtextBrush}" TextWrapping="Wrap" />
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ==================== FOOTER ==================== -->
        <Border Grid.Column="1" Grid.Row="1"
                Background="{StaticResource MantelBrush}"
                BorderBrush="{StaticResource Surface0Brush}"
                BorderThickness="0,1,0,0"
                Padding="24,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" FontSize="11"
                           Foreground="{StaticResource OverlayBrush}"
                           VerticalAlignment="Center">
                    <Run Text="SmartMacroAI v1.0.0" />
                    <Run Text=" | " />
                    <Run Text=".NET 8.0" />
                </TextBlock>
                <TextBlock FontSize="11" Foreground="{StaticResource SubtextBrush}"
                           VerticalAlignment="Center">
                    <Run Text="Created by Phạm Duy - Giải pháp tự động hóa thông minh." FontWeight="Medium" />
                </TextBlock>
            </DockPanel>
        </Border>

    </Grid>
</Window>

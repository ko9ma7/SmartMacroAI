<Window x:Class="SmartMacroAI.RunHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 Lịch sử chạy"
        Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E2E"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filter bar -->
        <Border Grid.Row="0" Background="#181825" Margin="0,0,0,1">
            <Grid Margin="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="📊 Lịch sử chạy macro"
                           Foreground="#CDD6F4" FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <TextBlock x:Name="TxtMacroNameFilter" Grid.Column="1"
                           Foreground="#FAB387" FontSize="13"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>

                <Button Grid.Column="2" Content="🗑 Xóa lịch sử"
                        Click="BtnClearHistory_Click"
                        Padding="12,6"
                        Background="#45475A" Foreground="#CDD6F4"
                        BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- History list -->
        <DataGrid Grid.Row="1" x:Name="HistoryGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="#1E1E2E"
                  RowBackground="#181825"
                  AlternatingRowBackground="#1E1E2E"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#313244"
                  RowHeight="40"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  SelectionChanged="HistoryGrid_SelectionChanged"
                  BorderThickness="0">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Kết quả" Binding="{Binding StatusIcon}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Thời gian"
                    Binding="{Binding StartTime, StringFormat='{}{0:dd/MM HH:mm:ss}'}"
                    Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#CDD6F4"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="8,0"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Tên macro" Binding="{Binding MacroName}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#CDD6F4"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Thời lượng" Binding="{Binding Duration}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#89B4FA"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Bước" Binding="{Binding StepsSummary}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#A6ADC8"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Chi tiết" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                <Button Content="📋 Log" Click="BtnViewLog_Click"
                                        Tag="{Binding}"
                                        Padding="6,3" Margin="2,0"
                                        Background="#45475A" Foreground="#CDD6F4"
                                        BorderThickness="0" Cursor="Hand" FontSize="11"/>
                                <Button Content="🖼" Click="BtnViewScreenshot_Click"
                                        Tag="{Binding}"
                                        Padding="6,3" Margin="2,0"
                                        Background="#45475A" Foreground="#CDD6F4"
                                        BorderThickness="0" Cursor="Hand" FontSize="11"
                                        Visibility="{Binding HasScreenshot, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Log preview panel -->
        <Border Grid.Row="2" Background="#181825" MaxHeight="150" Padding="12,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="📋 Log xem trước"
                           Foreground="#A6ADC8" FontSize="11" FontWeight="SemiBold"
                           Margin="0,0,0,6"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtLogPreview"
                               Foreground="#CDD6F4" FontSize="11"
                               FontFamily="Consolas"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
